pkgname=slime2
pkgdesc="Local Stream Widget Manager"
pkgver=1.0.0
pkgrel=1
arch=('x86_64' 'aarch64')
url="https://github.com/zaytri/slime2-desktop"
license=('AGPL-3.0-or-later')
depends=('cairo' 'desktop-file-utils' 'gdk-pixbuf2' 'glib2' 'gtk3' 'hicolor-icon-theme' 'libsoup3' 'pango' 'webkit2gtk-4.1' 'xdg-utils' 'gst-plugins-base' 'gst-plugins-good' 'gst-plugins-bad' 'gst-plugins-ugly')
options=('!strip' '!emptydirs')
install=${pkgname}.install
source_x86_64=("${url}/releases/download/v${pkgver}/Slime2-v${pkgver}_Linux-X64.deb")
source_aarch64=("${url}/releases/download/v${pkgver}/Slime2-v${pkgver}_Linux-ARM64.deb")
package() {
  # Extract package data
  tar -xvf data.tar.gz -C "${pkgdir}"
}