{
	"message-category": {
		"label": "Message",
		"settings": {
			"font-section": {
				"type": "section",
				"label": "Text",
				"settings": {
					"font-name": {
						"type": "font-input",
						"label": "Font",
						"halfSpan": true
					},
					"font-weight": {
						"type": "dropdown-input",
						"label": "Font Weight",
						"condition": {},
						"halfSpan": true,
						"defaultValue": 400,
						"options": [
							{
								"label": "Thin",
								"value": 100
							},
							{
								"label": "Extra-Light",
								"value": 200
							},
							{
								"label": "Light",
								"value": 300
							},
							{
								"label": "Normal",
								"value": 400
							},
							{
								"label": "Medium",
								"value": 500
							},
							{
								"label": "Semi-Bold",
								"value": 600
							},
							{
								"label": "Bold",
								"value": 700
							},
							{
								"label": "Extra-Bold",
								"value": 800
							},
							{
								"label": "Heavy",
								"value": 900
							}
						]
					},
					"font-size": {
						"type": "slider-input",
						"label": "Font Size (px)",
						"halfSpan": true,
						"defaultValue": 14,
						"min": 1,
						"max": 72,
						"step": 1
					},
					"message-color": {
						"type": "color-input",
						"label": "Message Color",
						"halfSpan": true,
						"defaultValue": "white"
					},
					"username-color": {
						"type": "dropdown-input",
						"label": "Username Color",
						"halfSpan": true,
						"defaultValue": "twitch-light",
						"options": [
							{
								"label": "Twitch",
								"value": "twitch"
							},
							{
								"label": "Twitch Light",
								"value": "twitch-light"
							},
							{
								"label": "Twitch Dark",
								"value": "twitch-dark"
							},
							{
								"label": "Custom",
								"value": "custom"
							}
						]
					},
					"custom-username-color": {
						"type": "color-input",
						"label": "Custom Username Color",
						"condition": {
							"username-color": "custom"
						},
						"halfSpan": true,
						"defaultValue": "white"
					},
					"max-lines": {
						"type": "slider-input",
						"label": "Max Lines",
						"defaultValue": 4,
						"min": 1,
						"max": 10,
						"step": 1
					},
					"max-width": {
						"type": "number-input",
						"label": "Max Message Width (px)",
						"defaultValue": 500,
						"min": 0,
						"max": 10000,
						"step": 1
					}
				}
			},
			"shadow-section": {
				"type": "section",
				"label": "Shadow",
				"settings": {
					"use-shadow": {
						"type": "toggle-input",
						"label": "Use Shadow?",
						"defaultValue": false,
						"description": "Applies a shadow to the message text, badges, and emotes."
					},
					"shadow-spread": {
						"type": "slider-input",
						"label": "Shadow Spread (px)",
						"condition": {
							"use-shadow": true
						},
						"halfSpan": true,
						"defaultValue": 0,
						"min": 0,
						"max": 10,
						"step": 1,
						"description": "Can be used to create an outline."
					},
					"shadow-blur": {
						"type": "slider-input",
						"label": "Shadow Blur (px)",
						"condition": {
							"use-shadow": true
						},
						"halfSpan": true,
						"defaultValue": 0,
						"min": 0,
						"max": 10,
						"step": 0.5
					},
					"shadow-offset-x": {
						"type": "slider-input",
						"label": "Shadow Offset Horizontal (px)",
						"condition": {
							"use-shadow": true
						},
						"halfSpan": true,
						"defaultValue": 0,
						"min": -10,
						"max": 10,
						"step": 1
					},
					"shadow-offset-y": {
						"type": "slider-input",
						"label": "Shadow Offset Vertical (px)",
						"condition": {
							"use-shadow": true
						},
						"halfSpan": true,
						"defaultValue": 0,
						"min": -10,
						"max": 10,
						"step": 1
					},
					"shadow-color": {
						"type": "color-input",
						"label": "Shadow Color",
						"condition": {
							"use-shadow": true
						},
						"defaultValue": "black"
					}
				}
			},
			"position-section": {
				"type": "section",
				"label": "Position",
				"settings": {
					"arrangement": {
						"type": "select-input",
						"label": "Message Arrangement",
						"defaultValue": "vertical",
						"options": [
							{
								"label": "Vertical",
								"value": "vertical"
							},
							{
								"label": "Horizontal",
								"value": "horizontal"
							}
						]
					},
					"vertical-flow": {
						"type": "select-input",
						"label": "Vertical Flow",
						"condition": {
							"arrangement": ["vertical"]
						},
						"halfSpan": true,
						"defaultValue": "to-top",
						"options": [
							{
								"label": "Bottom to Top",
								"value": "to-top"
							},
							{
								"label": "Top to Bottom",
								"value": "to-bottom"
							}
						]
					},
					"vertical-align": {
						"type": "select-input",
						"label": "Vertical Alignment",
						"condition": {
							"arrangement": ["vertical"]
						},
						"halfSpan": true,
						"defaultValue": "left",
						"options": [
							{
								"label": "Left",
								"value": "left"
							},
							{
								"label": "Right",
								"value": "right"
							}
						]
					},
					"horizontal-flow": {
						"type": "select-input",
						"label": "Horizontal Flow",
						"condition": {
							"arrangement": ["horizontal"]
						},
						"halfSpan": true,
						"defaultValue": "to-left",
						"options": [
							{
								"label": "Right to Left",
								"value": "to-left"
							},
							{
								"label": "Left to Right",
								"value": "to-right"
							}
						]
					},
					"horizontal-align": {
						"type": "select-input",
						"label": "Horizontal Alignment",
						"condition": {
							"arrangement": ["horizontal"]
						},
						"halfSpan": true,
						"defaultValue": "top",
						"options": [
							{
								"label": "Top",
								"value": "top"
							},
							{
								"label": "Bottom",
								"value": "bottom"
							}
						]
					}
				}
			},
			"badges-section": {
				"type": "section",
				"label": "Badges",
				"settings": {
					"hide-badges": {
						"type": "toggle-input",
						"label": "Hide Badges?",
						"defaultValue": false
					}
				}
			},
			"pronouns-section": {
				"type": "section",
				"label": "Pronouns",
				"settings": {
					"pronouns-text": {
						"type": "text-display",
						"label": "User pronouns are sourced from https://pr.alejo.io/ and https://pronoundb.org/"
					},
					"pronouns-display": {
						"type": "select-input",
						"label": "Pronouns Display",
						"defaultValue": "lowercase",
						"options": [
							{
								"label": "Lowercase",
								"value": "lowercase"
							},
							{
								"label": "Capitalized",
								"value": "capitalize"
							},
							{
								"label": "Uppercase",
								"value": "uppercase"
							},
							{
								"label": "Hidden",
								"value": "hidden"
							}
						]
					}
				}
			}
		}
	},
	"animation-category": {
		"label": "Animation",
		"settings": {
			"smooth-enter": {
				"type": "toggle-input",
				"label": "Use Smooth Scroll?",
				"defaultValue": true,
				"description": "Message size is animated with the enter animation."
			},
			"enter-animation": {
				"type": "dropdown-input",
				"label": "Enter Animation",
				"halfSpan": true,
				"defaultValue": "fade-in",
				"options": [
					{
						"label": "None",
						"value": "none"
					},
					{
						"label": "Fade In",
						"value": "fade-in"
					},
					{
						"label": "Fade In Left",
						"value": "fade-in-left"
					},
					{
						"label": "Fade In Right",
						"value": "fade-in-right"
					},
					{
						"label": "Fade In Up",
						"value": "fade-in-up"
					},
					{
						"label": "Fade In Down",
						"value": "fade-in-down"
					}
				]
			},
			"exit-animation": {
				"type": "dropdown-input",
				"label": "Exit Animation",
				"halfSpan": true,
				"defaultValue": "fade-out",
				"options": [
					{
						"label": "None",
						"value": "none"
					},
					{
						"label": "Fade Out",
						"value": "fade-out"
					},
					{
						"label": "Fade Out Left",
						"value": "fade-out-left"
					},
					{
						"label": "Fade Out Right",
						"value": "fade-out-right"
					},
					{
						"label": "Fade Out Up",
						"value": "fade-out-up"
					},
					{
						"label": "Fade Out Down",
						"value": "fade-out-down"
					}
				]
			}
		}
	},
	"lifetime-category": {
		"label": "Lifetime",
		"settings": {
			"delay": {
				"type": "slider-input",
				"label": "Message Delay (seconds)",
				"halfSpan": true,
				"defaultValue": 0,
				"min": 0,
				"max": 30,
				"step": 1
			},
			"max-messages": {
				"type": "slider-input",
				"label": "Max Messages",
				"halfSpan": true,
				"defaultValue": 50,
				"min": 1,
				"max": 200,
				"step": 1
			},
			"hide-clipping": {
				"type": "toggle-input",
				"label": "Hide messages that clip out of bounds?",
				"defaultValue": true
			},
			"expire-messages": {
				"type": "toggle-input",
				"label": "Hide messages after some time?",
				"halfSpan": true,
				"defaultValue": false
			},
			"hide-time": {
				"type": "number-input",
				"label": "Hide Time (seconds)",
				"condition": {
					"expire-messages": true
				},
				"halfSpan": true,
				"defaultValue": 300,
				"min": 1,
				"step": 1
			}
		}
	},
	"filters-category": {
		"label": "Filters",
		"settings": {
			"user-filters": {
				"type": "section",
				"label": "User Filters",
				"settings": {
					"hide-users": {
						"type": "multi-text-input",
						"label": "Hide Users",
						"defaultValue": ["Sery_Bot"],
						"placeholder": "Name"
					},
					"follower-only": {
						"type": "toggle-input",
						"label": "Follower Only Mode",
						"halfSpan": true,
						"defaultValue": false
					},
					"follow-age": {
						"type": "number-input",
						"label": "Minimum follow age (hours)",
						"condition": {
							"follower-only": true
						},
						"halfSpan": true,
						"defaultValue": 0,
						"min": 0,
						"step": "any",
						"description": "Will only show messages from followers that have followed for at least this many hours."
					}
				}
			},
			"message-filters": {
				"type": "section",
				"label": "Message Filters",
				"settings": {
					"hide-prefixes": {
						"type": "multi-text-input",
						"label": "Hide messages starting with:",
						"halfSpan": true,
						"defaultValue": ["!"],
						"placeholder": "Prefix"
					},
					"hide-words": {
						"type": "multi-text-input",
						"label": "Hide messages containing these words:",
						"halfSpan": true,
						"placeholder": "Bad Word"
					},
					"hide-first-chat": {
						"type": "toggle-input",
						"label": "Hide First Time Chat Messages?",
						"defaultValue": false
					}
				}
			}
		}
	},
	"sound-category": {
		"label": "Sound Effect",
		"settings": {
			"sound": {
				"type": "audio-input",
				"label": "Sound",
				"halfSpan": true,
				"description": "Play this sound effect for every chat message."
			},
			"sound-cooldown": {
				"type": "slider-input",
				"label": "Cooldown (seconds)",
				"halfSpan": true,
				"defaultValue": 5,
				"min": 0,
				"max": 600,
				"step": 1,
				"description": "Minimum time between playing sounds."
			}
		}
	}
}
