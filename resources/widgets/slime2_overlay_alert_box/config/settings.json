{
	"global-category": {
		"label": "Global Options",
		"settings": {
			"global-description": {
				"type": "text-display",
				"label": "These options will be applied to all alerts."
			},
			"delay": {
				"type": "slider-input",
				"label": "Alert Delay (seconds)",
				"halfSpan": true,
				"defaultValue": 0,
				"min": 0,
				"max": 30,
				"step": 1
			},
			"use-interrupt": {
				"type": "toggle-input",
				"label": "Allow Alert Interruption?",
				"halfSpan": true,
				"defaultValue": false,
				"description": "New alerts will replace any alert that is already playing."
			},
			"hide-words": {
				"type": "multi-text-input",
				"label": "Hide alerts that contain these words:",
				"placeholder": "Bad Word"
			}
		}
	},
