{
	"name": "slime2-widget-server",
	"version": "0.0.1",
	"description": "Widget Overlay Server for Slime2",
	"private": true,
	"type": "module",
	"scripts": {
		"start": "npm run dev",
		"dev": "vite",
		"build": "tsc -b && vite build --base=/overlay_server/ --emptyOutDir",
		"lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
		"preview": "vite preview"
	},
	"dependencies": {
		"@tailwindcss/vite": "^4.1.4",
		"@tanstack/react-router": "^1.81.6",
		"axios": "^1.7.7",
		"clsx": "^2.1.1",
		"nanoid": "^5.0.8",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"tailwindcss": "^4.1.4",
		"zod": "^4.0.10"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@tanstack/react-router-devtools": "^1.120.3",
		"@tanstack/router-plugin": "^1.81.6",
		"@types/node": "^25.6.0",
		"@types/react": "^19.0.7",
		"@types/react-dom": "^19.0.3",
		"@vitejs/plugin-react-swc": "^4.2.1",
		"babel-plugin-react-compiler": "^1.0.0",
		"eslint": "^9.39.4",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"globals": "^17.5.0",
		"prettier": "^3.3.2",
		"prettier-plugin-organize-imports": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.7.1",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.2",
		"vite": "^7.0.6",
		"vite-plugin-babel": "^1.6.0",
		"vite-tsconfig-paths": "^6.1.1"
	}
}
