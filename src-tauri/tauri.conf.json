{
	"build": {
		"beforeDevCommand": "npm run before:dev",
		"beforeBuildCommand": "npm run before:build",
		"frontendDist": "../dist",
		"devUrl": "http://localhost:57142"
	},
	"productName": "Slime2",
	"mainBinaryName": "Slime2",
	"version": "../package.json",
	"identifier": "stream.slime2.desktop",
	"bundle": {
		"active": true,
		"createUpdaterArtifacts": true,
		"resources": {
			"../resources/overlay_server": "overlay_server/",
			"../resources/widgets": "widgets/",
			"../resources/assets": "assets/"
		},
		"category": "utility",
		"shortDescription": "Local Stream Widget Manager",
		"longDescription": "Manage and customize local stream widgets!",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"targets": ["appimage", "deb", "rpm", "msi", "dmg"],
		"linux": {
			"appimage": {
				"bundleMediaFramework": true
			}
		}
	},
	"app": {
		"windows": [
			{
				"title": "Slime2",
				"width": 1200,
				"height": 700,
				"minWidth": 1200,
				"minHeight": 700,
				"center": true,
				"acceptFirstMouse": true,
				"backgroundThrottling": "disabled",
				"generalAutofillEnabled": false
			}
		],
		"security": {
			"capabilities": [
				"default",
				"dialog",
				"clipboard",
				"path",
				"event",
				"version",
				"opener",
				"log",
				"window-state",
				"updater",
				"process"
			],
			"csp": {
				"default-src": ["'self'", "http://localhost:*"],
				"connect-src": [
					"ipc:",
					"http://ipc.localhost",
					"https://id.twitch.tv",
					"https://api.twitch.tv",
					"wss://eventsub.wss.twitch.tv",
					"https://api.pronouns.alejo.io",
					"https://pronoundb.org",
					"https://api.betterttv.net",
					"https://api.frankerfacez.com",
					"https://pluralmind.chat"
				],
				"style-src": ["'self'", "https://fonts.googleapis.com"],
				"font-src": ["https://fonts.gstatic.com"],
				"img-src": ["'self'", "http://localhost:*", "https:", "data:"],
				"worker-src": ["'self'", "http://localhost:*", "blob:"],
				"script-src-elem": ["'self'", "http://localhost:*"]
			}
		}
	},
	"plugins": {
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQwQ0Y5OTM1MjdGQjU3RTMKUldUalYvc25OWm5QUVBlVzBmcnlpS0NmVEIrMnpVeURBcnFOUnpHVlJrYUUrM2p0MWZwSmlUWTkK",
			"endpoints": [
				"https://github.com/zaytri/slime2-desktop/releases/download/latest.json"
			],
			"windows": {
				"installMode": "passive"
			}
		}
	}
}
