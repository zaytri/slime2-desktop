{
	"name": "slime2",
	"version": "1.3.0",
	"description": "Local Stream Widget Manager",
	"private": true,
	"type": "module",
	"scripts": {
		"start": "npm run dev",
		"dev": "concurrently --kill-others -n TAURI,OVERLAY -c green.bold,yellow.bold \"tauri dev\" \"npm:overlay:dev\"",
		"build": "tauri build",
		"build:debug": "tauri build --debug",
		"tauri": "tauri",
		"icon": "npm run tauri icon",
		"before:dev": "npm run clean:target && npm run overlay:build && npm run icon && vite",
		"before:build": "npm run clean:target && npm run overlay:build && npm run icon && tsc && vite build",
		"overlay:install": "cd ./src-overlay && npm install && cd ..",
		"overlay:dev": "npm run overlay:install && npm --prefix ./src-overlay/ run dev",
		"overlay:build": "npm run overlay:install && npm --prefix ./src-overlay/ run build",
		"clean:target": "cd ./src-tauri && cargo clean && cd .."
	},
	"dependencies": {
		"@ariakit/react": "^0.4.26",
		"@headlessui/react": "^2.2.0",
		"@tailwindcss/vite": "^4.1.4",
		"@tanstack/react-query": "^5.60.2",
		"@tauri-apps/api": "^2.1.1",
		"@tauri-apps/plugin-clipboard-manager": "^2.0.0",
		"@tauri-apps/plugin-dialog": "^2.0.1",
		"@tauri-apps/plugin-log": "^2.8.0",
		"@tauri-apps/plugin-opener": "^2.5.2",
		"@tauri-apps/plugin-shell": "^2.3.5",
		"@uiw/react-color": "^2.10.1",
		"axios": "^1.9.0",
		"clsx": "^2.1.0",
		"colorjs.io": "^0.6.1",
		"linkify-react": "^4.3.1",
		"linkifyjs": "^4.3.1",
		"nanoid": "^5.1.5",
		"pluralmind": "^1.1.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"tailwindcss": "^4.2.2",
		"zod": "^4.0.10"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@tanstack/eslint-plugin-query": "^5.99.0",
		"@tauri-apps/cli": "^2.1.0",
		"@types/react": "^19.0.7",
		"@types/react-dom": "^19.0.3",
		"@vitejs/plugin-react-swc": "^4.2.1",
		"babel-plugin-react-compiler": "^1.0.0",
		"concurrently": "^10.0.3",
		"eslint": "^9.39.4",
		"eslint-plugin-react": "^7.37.2",
		"eslint-plugin-react-hooks": "^7.0.1",
		"globals": "^17.5.0",
		"prettier": "^3.2.5",
		"prettier-plugin-jsdoc": "^1.3.3",
		"prettier-plugin-organize-imports": "^4.0.0",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.2",
		"vite": "^7.0.6",
		"vite-plugin-babel": "^1.6.0",
		"vite-tsconfig-paths": "^6.1.1"
	}
}
